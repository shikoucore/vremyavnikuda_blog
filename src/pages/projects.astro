---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ProjectsRoadmapVisualization from '@components/ProjectsRoadmapVisualization';
import { buildProjectRoadmapNodes, getProjectsEntriesForLang } from '../lib/projectsData';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = buildProjectRoadmapNodes(getProjectsEntriesForLang(await getCollection('projects'), lang));
const detailsUrl = `/projects-data/${lang}.json`;
---

<BaseLayout title={`${t('projects.title')} - vremyavnikuda`} description={t('projects.description')}>
  <div class="w-full px-2 py-4">
    {projects.length === 0 ? (
      <p class="text-[var(--color-text-secondary)]">{t('projects.noProjects')}</p>
    ) : (
      <ProjectsRoadmapVisualization projects={projects} detailsUrl={detailsUrl} lang={lang} client:load />
    )}
  </div>
</BaseLayout>
