---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => !post.data.draft && post.data.lang === 'en')
    .map((post) => ({
      params: { slug: post.slug.replace(/-en$/, '') },
      props: post,
    }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout 
  title={`${post.data.title} - vremyavnikuda`}
  description={post.data.description}
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']],
        processEscapes: true,
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
      },
    };
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" async></script>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-12">
      <time class="text-sm text-[var(--color-text-secondary)]">
        {post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
      <h1 class="text-4xl md:text-5xl font-bold mt-3 mb-6">
        {post.data.title}
      </h1>
    </header>

    <div class="prose prose-lg max-w-none article-prose">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a 
        href="/en/blog" 
        class="inline-flex items-center text-primary-400 hover:underline"
      >
        ← Back to blog
      </a>
    </footer>
  </article>
</BaseLayout>
