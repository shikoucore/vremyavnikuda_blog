---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations, getLocalizedPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => !post.data.draft && post.data.lang === 'ja')
    .map((post) => ({
      params: { slug: post.slug },
      props: post,
    }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
const t = useTranslations('ja');
const lang = 'ja';
---

<BaseLayout 
  title={`${post.data.title} - vremyavnikuda`}
  description={post.data.description}
>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-12">
      <time class="text-sm text-[var(--color-text-secondary)]">
        {post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
      <h1 class="text-4xl md:text-5xl font-bold mt-3 mb-6">
        {post.data.title}
      </h1>
    </header>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a 
        href={getLocalizedPath('/blog', lang)}
        class="inline-flex items-center text-primary-400 hover:underline"
      >
        {t('blog.backToBlog')}
      </a>
    </footer>
  </article>
</BaseLayout>
